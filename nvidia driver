#LTS kernels are supported for ~2 years.
#NVIDIA 470xx works on:
 - 6.1 LTS
 - 6.6 LTS

  #Check current kernel version
uname -r

#For updates it is good to stop kernel updates completely
  #Option A — Ignore kernel packages in pacman.conf
sudo nano /etc/pacman.conf
    #Add line
  IgnorePkg = linux linux-headers linux-lts linux-lts-headers

  #Option B — Freeze only LTS kernel
    #Add line  
  IgnorePkg = linux-lts linux-lts-headers

  #Option C — Freeze ALL kernel-related packages
    #Add line
  IgnoreGroup = kernel


